@inherits LayoutComponentBase

<div class="page">
    <main>
        <!-- Modern Top Navigation Bar -->
        <nav class="navbar navbar-expand-md navbar-dark bg-dark mb-4 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="events">
                    <span class="text-primary">Event</span>Ease
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <ul class="navbar-nav ms-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="events" Match="NavLinkMatch.All">
                                📅 Dashboard
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="tracker">
                                ✅ My Attendance
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="btn btn-primary ms-2" href="register">
                                👤 Register / Login
                            </NavLink>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Main Content Area where pages load -->
        <article class="content px-4">
            @Body
        </article>

        <!-- Simple Footer -->
        <footer class="text-center text-muted mt-5 py-4 border-top">
            <div class="container">
                <small>&copy; 2026 EventEase - Built with .NET Blazor WebAssembly</small>
            </div>
        </footer>
    </main>
    </div>